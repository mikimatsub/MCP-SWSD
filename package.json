{
  "name": "swsd-mcp",
  "version": "0.4.0",
  "description": "MCP server for SolarWinds Service Desk (SWSD / Samanage). Dual transport: stdio for local agents, Streamable HTTP for Copilot Studio and hosted deployments.",
  "type": "module",
  "engines": {
    "node": ">=24.15.0 <25"
  },
  "bin": {
    "swsd-mcp": "dist/cli.js"
  },
  "main": "dist/cli.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "inspect:stdio": "npx -y @modelcontextprotocol/inspector node dist/cli.js --transport=stdio",
    "inspect:http": "npx -y @modelcontextprotocol/inspector",
    "generate:swagger": "tsx scripts/generate-copilot-swagger.ts",
    "dump:custom-fields": "tsx scripts/dump-custom-fields.ts"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "solarwinds",
    "samanage",
    "service-desk",
    "swsd",
    "itsm",
    "copilot-studio"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "express": "5.2.1",
    "express-rate-limit": "8.4.1",
    "zod": "4.4.2"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/express": "5.0.6",
    "@types/node": "^24.12.2",
    "eslint": "10.3.0",
    "globals": "17.6.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.1",
    "vitest": "4.1.5"
  }
}
