# === Required (stdio transport) ===

# Your SolarWinds Service Desk API token (JWT).
# Required for stdio mode. For http mode, the token is per-request via the
# Authorization or X-SWSD-Token header instead — see README "HTTP transport".
SWSD_TOKEN=

# === SWSD endpoint configuration ===

# Regional SWSD API base URL.
#   US tenants: https://api.samanage.com (default)
#   EU tenants: https://apieu.samanage.com
SWSD_BASE_URL=https://api.samanage.com

# SWSD API version. Defaults to v2.1 (current). Override only if your tenant
# requires v1.1 or another version (rare).
SWSD_API_VERSION=v2.1

# === Server behavior ===

# Transport: stdio (default, for local agent clients) or http (for hosted /
# Copilot Studio).
SWSD_TRANSPORT=stdio

# Profile: triage, agent, knowledge, or full. Determines the set of tools
# registered at startup.
SWSD_PROFILE=agent

# Comma-separated extra tool names to enable on top of the profile.
# Unknown names cause a startup error (loud-fail by design).
# Example: SWSD_ENABLE_EXTRAS=swsd_create_incident,swsd_update_incident
SWSD_ENABLE_EXTRAS=

# === HTTP transport only ===

# Listen port. Default 3000.
PORT=3000

# Comma-separated allowed Origin headers. Empty = no Origin restrictions
# (acceptable behind a trusted reverse proxy; otherwise set explicitly).
# Spec recommends Origin validation to prevent DNS rebinding attacks.
SWSD_ALLOWED_ORIGINS=

# === Reliability ===

# Max retry attempts for retryable errors (5xx and network failures on GETs).
SWSD_RETRY_MAX_ATTEMPTS=3
