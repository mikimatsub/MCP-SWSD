# Build output
dist/
*.tsbuildinfo

# Dependencies
node_modules/

# Test artifacts
coverage/
.vitest-cache/
.nyc_output/

# npm pack tarballs (created by `npm pack`; CI uses `--dry-run`)
*.tgz

# Environment files (allowlist .env.example for documentation)
.env
.env.*
!.env.example

# Tenant-specific captures (e.g., custom-field schema dumps)
validation/

# Secrets — never commit these. Listed defensively even though
# we never intentionally place them here.
*.pem
*.key
*.crt
*.p12
*.pfx
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*

# Logs
*.log

# Editor / IDE
.vscode/
.idea/
.history/
*.swp
*.swo
*~

# OS noise
.DS_Store
Thumbs.db
Desktop.ini

# Tool caches
.cache/

# Playwright MCP browser automation artifacts (snapshots, console logs, evaluations)
.playwright-mcp/

# Temporary release-note staging (do not commit; one-off content for gh release create)
.release-notes-temp/
